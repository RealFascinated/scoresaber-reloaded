{
  "name": "scoresaber-reloaded",
  "version": "1.0.0",
  "workspaces": {
    "nohoist": [
      "**/projects/website/**",
      "**/projects/website"
    ],
    "packages": [
      "projects/*"
    ]
  },
  "scripts": {
    "prettier": "prettier --write .",
    "lint:all": "eslint -c projects/backend/eslint.config.mjs \"projects/backend/**/*.ts\" && eslint -c projects/website/eslint.config.mjs \"projects/website/src/**/*.ts\" \"projects/website/src/**/*.tsx\"",
    "count-lines": "find projects -type f -not -path '*/dist/*' -not -path '*/.next/*' -not -path '*/node_modules/*' -name '*.ts' -o -name '*.tsx' | xargs wc -l"
  },
  "author": "fascinated7",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^10.1.0"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
