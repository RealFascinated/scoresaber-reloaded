{
  "name": "scoresaber-reloaded",
  "version": "1.0.0",
  "workspaces": {
    "nohoist": [
      "**/projects/website/**",
      "**/projects/website"
    ],
    "packages": [
      "projects/*"
    ]
  },
  "scripts": {
    "prettier": "prettier --write .",
    "lint": "bun run lint:all",
    "lint:backend": "cd projects/backend && bun run lint",
    "lint:website": "cd projects/website && bun run lint",
    "lint:common": "cd projects/common && bun run lint",
    "lint:all": "bun run lint:backend && bun run lint:website && bun run lint:common",
    "update": "bun run update:all",
    "update:backend": "cd projects/backend && bun update",
    "update:website": "cd projects/website && bun update",
    "update:common": "cd projects/common && bun update",
    "update:all": "bun run update:backend && bun run update:website && bun run update:common",
    "count-lines": "find projects -type f -not -path '*/dist/*' -not -path '*/.next/*' -not -path '*/node_modules/*' -name '*.ts' -o -name '*.tsx' | xargs wc -l"
  },
  "author": "fascinated7",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^9.39.4"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
}
