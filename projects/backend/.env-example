# App identity (required — must be "backend" for this service)
NEXT_PUBLIC_APPLICATION_NAME=backend
NEXT_PUBLIC_APP_ENV=development

# Public URLs (shared with website; used in Discord embeds, playlists, leaderboards, etc.)
NEXT_PUBLIC_WEBSITE_NAME=ScoreSaber Reloaded
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_CDN_URL=http://localhost:9000
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8080

# Logging
LOG_LEVEL=debug

# PostgreSQL (required)
DATABASE_URL=postgresql://user:password@localhost:5432/scoresaber_reloaded

# MongoDB (required by env schema; legacy / auxiliary storage)
MONGO_CONNECTION_STRING=mongodb://localhost:27017/scoresaber_reloaded

# Redis (required)
REDIS_URL=redis://localhost:6379/0

# Object storage / S3-compatible (required)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Background queues (player score refresh, leaderboard seed, etc.)
ENABLE_QUEUES=true

# Prometheus metrics scrape auth (required)
PROMETHEUS_AUTH_TOKEN=

# Discord bot (optional — omit token to disable the bot)
DISCORD_BOT_TOKEN=

# Discord log / feed channels (optional)
# DISCORD_CHANNEL_TRACKED_PLAYER_LOGS=
# DISCORD_CHANNEL_PLAYER_SCORE_REFRESH_LOGS=
# DISCORD_CHANNEL_RANKED_BATCH_LOGS=
# DISCORD_CHANNEL_NUMBER_ONE_FEED=
# DISCORD_CHANNEL_TOP_50_SCORES_FEED=
# DISCORD_CHANNEL_SCORE_FLOODGATE_FEED=
# DISCORD_CHANNEL_MEDAL_SCORES_FEED=
# DISCORD_CHANNEL_BACKEND_LOGS=
# DISCORD_CHANNEL_BEATSAVER_LOGS=

# Analytics (optional; website-only, safe to leave unset on backend)
# NEXT_PUBLIC_ANALYTICS_WEBSITE_ID=
# NEXT_PUBLIC_ANALYTICS_SCRIPT_URL=
