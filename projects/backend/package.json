{
  "name": "backend",
  "version": "1.0.0",
  "exports": {
    "./db": "./src/db/index.ts",
    "./db/schema": "./src/db/schema.ts"
  },
  "scripts": {
    "db:migrate": "bun run scripts/db-migrate.ts",
    "create-missing-leaderboards": "bun run scripts/create-missing-scoresaber-leaderboards.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --compile --target bun --outfile ssr-backend src/index.js",
    "start": "NODE_ENV=production ./ssr-backend",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@discordx/importer": "^1.3.3",
    "@discordx/utilities": "^8.0.0",
    "@dotenvx/dotenvx": "^1.60.2",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@ssr/common": "workspace:common",
    "@tqman/nice-logger": "^1.1.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "devalue": "^5.7.0",
    "discord.js": "^14.26.2",
    "discordx": "^11.13.3",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "elysia-helmet": "^3.1.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "ioredis": "^5.10.1",
    "prom-client": "^15.1.3",
    "systeminformation": "^5.31.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
